# ──────────────────────────────────────────
# AaramKart — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL only). Supabase = Postgres: set DATABASE_URL from the dashboard.
#
# 1) Supabase → Project Settings → Database
# 2) Copy "Connection string" → URI (mode: "Session" or use Direct connection for migrate).
# 3) Paste into .env as DATABASE_URL=...  OR SUPABASE_DATABASE_URL=... (same URI; either key works)
# 4) Run: .\scripts\supabase-connect.ps1   OR:  python manage.py check_database --migrate
#
# Direct (recommended for Django migrate / local dev):
#   postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#   OR host db.[ref].supabase.co port 5432 — copy exact URI from Supabase.
# Transaction pooler port 6543: supported (settings set DISABLE_SERVER_SIDE_CURSORS).
# sslmode=require is added automatically for hosts containing "supabase".
# Pool issues: try DB_CONN_MAX_AGE=0
#
# ── Railway (production) ───────────────────────────────────────────────────
# In the Railway service → Variables, add at least:
#   DATABASE_URL = Supabase Postgres URI (same as above)
#   SECRET_KEY = a long random string (not the Django dev default)
#   ALLOWED_HOSTS = your hostname, e.g. araamkart-production.up.railway.app
#   CSRF_TRUSTED_ORIGINS = https://araamkart-production.up.railway.app  (same host, https)
# Optional: DEBUG=False
# Redeploy after saving variables. Repo includes nixpacks.toml for libpq + gunicorn start.
#
# Local Postgres: leave DATABASE_URL / SUPABASE_* URL empty and use POSTGRES_* below.
DATABASE_URL=
# SUPABASE_DATABASE_URL=
POSTGRES_DB=aaramkart
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=AaramKart <your-email@gmail.com>

# Admin Contact (receives order notifications)
ADMIN_EMAIL=admin@aaramkart.com
ADMIN_PHONE=+919999999999

# One-time local bootstrap: create/update superuser matching ADMIN_PHONE + ADMIN_EMAIL
# python manage.py bootstrap_admin
# Then remove these lines from .env (do not commit real passwords).
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_FULL_NAME=Admin

# SMS OTP Provider (Fast2SMS — leave blank to use console fallback)
FAST2SMS_API_KEY=

# WhatsApp (CallMeBot — leave blank to skip)
CALLMEBOT_API_KEY=
CALLMEBOT_PHONE=
