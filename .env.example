# ──────────────────────────────────────────
# AaramKart — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite is default; switch for PostgreSQL)
# DATABASE_URL=postgres://user:password@localhost:5432/aaramkart

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=AaramKart <your-email@gmail.com>

# Admin Contact (receives order notifications)
ADMIN_EMAIL=admin@aaramkart.com
ADMIN_PHONE=+919999999999

# SMS OTP Provider (Fast2SMS — leave blank to use console fallback)
FAST2SMS_API_KEY=

# WhatsApp (CallMeBot — leave blank to skip)
CALLMEBOT_API_KEY=
CALLMEBOT_PHONE=
