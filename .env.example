# ──────────────────────────────────────────
# AaramKart — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL only)
# Prefer DATABASE_URL (e.g. on Heroku/Railway). Leave it empty to use POSTGRES_* only.
DATABASE_URL=postgres://postgres:password@localhost:5432/aaramkart
POSTGRES_DB=aaramkart
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=AaramKart <your-email@gmail.com>

# Admin Contact (receives order notifications)
ADMIN_EMAIL=admin@aaramkart.com
ADMIN_PHONE=+919999999999

# One-time local bootstrap: create/update superuser matching ADMIN_PHONE + ADMIN_EMAIL
# python manage.py bootstrap_admin
# Then remove these lines from .env (do not commit real passwords).
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_FULL_NAME=Admin

# SMS OTP Provider (Fast2SMS — leave blank to use console fallback)
FAST2SMS_API_KEY=

# WhatsApp (CallMeBot — leave blank to skip)
CALLMEBOT_API_KEY=
CALLMEBOT_PHONE=
