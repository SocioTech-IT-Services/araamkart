{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "preDeployCommand": ["python", "manage.py", "migrate", "--noinput"],
    "startCommand": "sh -c \"exec gunicorn aaramkart.wsgi:application --bind 0.0.0.0:${PORT:-8080} --worker-class gthread --workers 2 --threads 4 --timeout 120 --graceful-timeout 30 --access-logfile - --error-logfile -\"",
    "healthcheckPath": "/_health/",
    "healthcheckTimeout": 300
  }
}
